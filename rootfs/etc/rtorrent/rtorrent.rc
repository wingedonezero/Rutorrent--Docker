# Minimal, near-stock rtorrent config.
# No move-on-complete, no temp/complete split, no auto-rehash. A default install
# already downloads to ONE directory and seeds in place — we just keep it that way.

# Run in the background (no controlling terminal needed)
system.daemon.set = true

# SCGI socket for ruTorrent. php-fpm runs as the SAME user as rtorrent,
# so the socket is accessible without any chmod/schedule trickery.
network.scgi.open_local = /config/.rtorrent.sock

# Session state (the torrent list) and the single download directory
session.path.set = /config/session
directory.default.set = /downloads

# Permissions: downloaded files readable/writable by everyone (umask 0000 = files 666, dirs 777),
# so Jellyfin/other apps on the box can use them. Change to 0022 if you want stock-tight perms.
system.umask.set = 0000

# Incoming peer port (forward this on the router for good connectivity)
network.port_range.set = 50000-50000
network.port_random.set = no

# Private-tracker friendly: no DHT, no peer-exchange
dht.mode.set = disable
protocol.pex.set = no

# Encryption: accept anything, prefer encrypted outgoing
protocol.encryption.set = allow_incoming,try_outgoing,enable_retry

# Do NOT re-hash a torrent the moment it finishes
pieces.hash.on_completion.set = no

# Log to a file so we can see what rtorrent is doing
log.open_file = "log", /config/rtorrent.log
log.add_output = "info", "log"
