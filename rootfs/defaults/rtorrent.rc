# ===================================================================
#  rtorrent config — EDIT THIS FILE to change rtorrent's behaviour.
#  It lives in your appdata at /config/rtorrent/rtorrent.rc and your
#  edits persist (the container only seeds a default here on first run).
#  Restart the container after editing.
# ===================================================================

# Run headless (no terminal)
system.daemon.set = true

# SCGI socket for ruTorrent (php-fpm runs as the same user, so no chmod needed)
network.scgi.open_local = /config/rtorrent/.rtorrent.sock

# Session state + the single download directory
session.path.set = /config/rtorrent/session
directory.default.set = /downloads

# Permissions: downloads come out 666/777 so other apps (Plex/Jellyfin) can read them.
# Change to 0022 for stock-tight perms.
system.umask.set = 0000

# Cap the memory-mapped chunk cache. rtorrent 0.16 defaults this to ~32 GB, which LOOKS alarming in
# the UI / Unraid memory stat — but it's reclaimable cache, not real RAM usage. 4 GB is plenty for a
# small seedbox and keeps the reported memory sane. Raise it if you want more file caching.
pieces.memory.max.set = 4G

# Incoming peer port (forward this on the router)
network.port_range.set = 50000-50000
network.port_random.set = no

# DHT "auto" + peer-exchange: used for PUBLIC torrents, automatically skipped for PRIVATE ones
# (their "private" flag disables DHT/PEX), so it's safe on private trackers AND works for public.
# DHT uses the listening port (50000) below. If you run ONLY private trackers and want to be
# extra-safe, set dht.mode.set = disable and protocol.pex.set = no.
dht.mode.set = auto
protocol.pex.set = yes

# Encryption: accept anything, prefer encrypted outgoing
protocol.encryption.set = allow_incoming,try_outgoing,enable_retry

# Don't re-hash a torrent the moment it finishes
pieces.hash.on_completion.set = no

# Logging (lives in your appdata at /config/log/rtorrent.log)
log.open_file = "log", /config/log/rtorrent.log
log.add_output = "info", "log"
