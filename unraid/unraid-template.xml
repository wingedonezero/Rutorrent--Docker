<?xml version="1.0"?>
<Container version="2">
  <Name>rtorrent-rutorrent</Name>
  <Repository>ghcr.io/wingedonezero/rtorrent-rutorrent:latest</Repository>
  <Registry/>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support/>
  <Project/>
  <Overview>Lean rtorrent + ruTorrent on Arch Linux (glibc). Single download directory, no move-on-complete, no auto-rehash. Built in-house.</Overview>
  <Category>Downloaders:</Category>
  <WebUI>http://[IP]:[PORT:8080]/</WebUI>
  <TemplateURL/>
  <Icon>https://raw.githubusercontent.com/Novik/ruTorrent/master/images/favicon-196x196.png</Icon>
  <ExtraParams>--stop-timeout=30</ExtraParams>
  <PostArgs/>
  <CPUset/>
  <DateInstalled>0</DateInstalled>
  <DonateText/>
  <DonateLink/>
  <Description>Lean rtorrent + ruTorrent on Arch Linux (glibc).</Description>
  <Networking>
    <Mode>bridge</Mode>
  </Networking>
  <Data/>
  <Environment/>
  <Labels/>
  <Config Name="WebUI Port" Target="8080" Default="8080" Mode="tcp" Description="ruTorrent web UI" Type="Port" Display="always" Required="true" Mask="false">8080</Config>
  <Config Name="Peer Port" Target="50000" Default="50000" Mode="tcp" Description="Incoming peer port (forward this on the router)" Type="Port" Display="always" Required="false" Mask="false">50000</Config>
  <Config Name="Config (appdata)" Target="/config" Default="/mnt/user/appdata/rutorrent" Mode="rw" Description="rtorrent session + ruTorrent settings (persists here)" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/rutorrent</Config>
  <Config Name="Downloads" Target="/downloads" Default="" Mode="rw,slave" Description="Download directory. An Unassigned Devices drive MUST use RW/Slave." Type="Path" Display="always" Required="true" Mask="false">/mnt/disks/2BH7ETPR/downloads</Config>
  <Config Name="PUID" Target="PUID" Default="99" Mode="" Description="User ID (Unraid = 99)" Type="Variable" Display="always" Required="true" Mask="false">99</Config>
  <Config Name="PGID" Target="PGID" Default="100" Mode="" Description="Group ID (Unraid = 100)" Type="Variable" Display="always" Required="true" Mask="false">100</Config>
  <Config Name="TZ" Target="TZ" Default="UTC" Mode="" Description="Timezone" Type="Variable" Display="always" Required="false" Mask="false">America/New_York</Config>
</Container>
